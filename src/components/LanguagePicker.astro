---
import { getLangFromUrl, useTranslatedPath, getRouteFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
const currentRoute = getRouteFromUrl(Astro.url) || '/';
---

<div class="fixed bottom-4 right-4 flex items-center gap-1 text-sm z-50">
  <a
    href={translatePath(currentRoute, 'en')}
    class={`px-2 py-1 rounded transition-colors ${lang === 'en' ? 'font-semibold text-link dark:text-link-dark' : 'text-text-secondary dark:text-text-secondary-dark hover:bg-paper-border dark:hover:bg-paper-border-dark'}`}
    aria-label="English"
  >EN</a>
  <span class="text-text-secondary dark:text-text-secondary-dark select-none">/</span>
  <a
    href={translatePath(currentRoute, 'zh')}
    class={`px-2 py-1 rounded transition-colors ${lang === 'zh' ? 'font-semibold text-link dark:text-link-dark' : 'text-text-secondary dark:text-text-secondary-dark hover:bg-paper-border dark:hover:bg-paper-border-dark'}`}
    aria-label="中文"
  >中文</a>
</div>
