---
import { getLangFromUrl, useTranslatedPath, getRouteFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
const currentRoute = getRouteFromUrl(Astro.url) || '/';
---

<div class="lang-switcher">
  <a
    href={translatePath(currentRoute, 'en')}
    class:list={['lang-btn', { active: lang === 'en' }]}
    aria-label="English"
  >EN</a>
  <span class="lang-sep">/</span>
  <a
    href={translatePath(currentRoute, 'zh')}
    class:list={['lang-btn', { active: lang === 'zh' }]}
    aria-label="中文"
  >中文</a>
</div>

<style>
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.875rem;
  }
  .lang-btn {
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    text-decoration: none;
    color: var(--text-secondary, #6b7280);
    transition: all 0.15s;
  }
  .lang-btn:hover {
    background: var(--bg-hover, #f3f4f6);
    color: var(--text-primary, #374151);
  }
  .lang-btn.active {
    color: var(--accent, #3b82f6);
    font-weight: 600;
  }
  .lang-sep {
    color: var(--text-tertiary, #9ca3af);
    user-select: none;
  }
  :global(html.dark) .lang-btn {
    color: var(--text-secondary, #9ca3af);
  }
  :global(html.dark) .lang-btn:hover {
    background: var(--bg-hover, #374151);
    color: var(--text-primary, #f3f4f6);
  }
  :global(html.dark) .lang-btn.active {
    color: var(--accent, #60a5fa);
  }
</style>
