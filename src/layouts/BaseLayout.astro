---
import '../styles/global.css';
import { getSpriteUrl } from '../data/sprite-sources';

// Fetch Pokemon names from pokesprite at build time
const POKESPRITE_BASE = 'https://raw.githubusercontent.com/msikma/pokesprite/master/pokemon-gen8';
const POKESPRITE_REGULAR_URL = `https://api.github.com/repos/msikma/pokesprite/contents/pokemon-gen8/regular`;

// Get the list of Pokemon names at build time
let pokespriteNames: string[] = [];
try {
  const response = await fetch(POKESPRITE_REGULAR_URL);
  if (response.ok) {
    const files = await response.json();
    pokespriteNames = files
      .filter((f: any) => f.name.endsWith('.png'))
      .map((f: any) => f.name.replace('.png', ''));
  }
} catch {
  pokespriteNames = [];
}

interface Props {
  title: string;
  description?: string;
}

const {
  title = 'Sprites Gallery',
  description = 'Pokemon sprite source comparison gallery',
} = Astro.props;

const defaultTemplate = getSpriteUrl('showdown', 1);
const canonicalURL = 'https://wangrui2025.github.io/sprites-gallery-byname-myk/';
const defaultId = 1;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={defaultTemplate} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={defaultTemplate} />

    <!-- Performance: preconnect to sprite CDN -->
    <link rel="dns-prefetch" href="https://raw.githubusercontent.com" />
    <link rel="preconnect" href="https://raw.githubusercontent.com" crossorigin />

    <link id="pokemon-favicon" rel="icon" type="image/png" href="" />
    <script is:inline define:vars={{ pokespriteNames, POKESPRITE_BASE }}>
      (function() {
        // Randomly pick a Pokemon name from pokesprite
        var randomName = pokespriteNames[Math.floor(Math.random() * pokespriteNames.length)];
        if (!randomName) return;

        localStorage.setItem('preferred-pokemon-name', randomName);
        window.__INITIAL_POKEMON_NAME__ = randomName;

        // Set favicon to pokesprite Gen 8 regular sprite URL (68x56)
        var url = POKESPRITE_BASE + '/regular/' + randomName + '.png';
        var link = document.getElementById('pokemon-favicon');
        if (link) link.href = url;
      })();
    </script>

    <!-- Theme initialization -->
    <script is:inline>
      (function() {
        function applyTheme() {
          const theme = localStorage.getItem('theme')
            || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.classList.toggle('dark', theme === 'dark');
        }
        applyTheme();
      })();
    </script>
  </head>

  <body>
    <slot />
  </body>
</html>
