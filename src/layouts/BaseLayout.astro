---
import '../styles/global.css';
import { getLangFromUrl } from '../i18n/utils';
import LanguagePicker from '../components/LanguagePicker.astro';
import manifest from '../data/favicon-manifest.json';

interface Props {
  title: string;
  description?: string;
}

const {
  title = 'Sprites Gallery',
  description = 'Pokemon sprite source comparison gallery',
} = Astro.props;

const currentLang = getLangFromUrl(Astro.url);
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const defaultTemplate = 'https://play.pokemonshowdown.com/sprites/gen5/1.png';
const defaultId = 1;

// Build all favicon URLs (regular + shiny) at build time
const faviconUrls = manifest.iconSets
  .filter(s => s.id === 'regular' || s.id === 'shiny')
  .flatMap(s => s.icons)
  .map(i => i.url);
---

<!doctype html>
<html lang={currentLang} class="bg-bg dark:bg-bg-dark text-text dark:text-text-dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={defaultTemplate} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={defaultTemplate} />

    <!-- Performance: preconnect to sprite CDN -->
    <link rel="dns-prefetch" href="https://raw.githubusercontent.com" />
    <link rel="preconnect" href="https://raw.githubusercontent.com" crossorigin />
    <link rel="dns-prefetch" href="https://play.pokemonshowdown.com" />
    <link rel="preconnect" href="https://play.pokemonshowdown.com" crossorigin />

    <!-- Preload initial Pokemon sprite (first visible source) -->
    <link
      rel="preload"
      as="image"
      href={`https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/${defaultId}.png`}
    />

    <link id="pokemon-favicon" rel="icon" type="image/png" href="/sprites-gallery/favicons/msikma_pokesprite/pokemon-gen8/regular/lotad.png" />
    <link rel="manifest" href="/sprites-gallery/manifest.json" />
    <meta name="theme-color" content="#3b82f6" />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sprites-gallery/sw.js').catch(() => {});
        });
      }
    </script>
    <script is:inline define:vars={{ faviconUrls }}>
      (function() {
        // Default to Lotad (first icon)
        var link = document.getElementById('pokemon-favicon');
        if (!link) return;

        // True random each visit from regular + shiny icons
        var randomUrl = faviconUrls[Math.floor(Math.random() * faviconUrls.length)];
        link.href = randomUrl;
      })();
    </script>

    <script is:inline define:vars={{ defaultTemplate, defaultId }}>
      (function() {
        var initialId = Math.floor(Math.random() * 898) + 1;
        window.__INITIAL_POKEMON_ID__ = initialId;
      })();
    </script>

    <!-- Theme initialization -->
    <script is:inline>
      (function() {
        function applyTheme() {
          const theme = localStorage.getItem('theme')
            || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.classList.toggle('dark', theme === 'dark');
        }
        applyTheme();
      })();
    </script>
  </head>

  <body class="m-0 min-h-screen leading-relaxed">
    <slot />
    <LanguagePicker />
  </body>
</html>
