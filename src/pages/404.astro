---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl } from '../i18n/utils';
import { ui } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = ui[lang];
---

<BaseLayout title={t['error.pageNotFound']} description={t['error.description']}>
  <div class="max-w-7xl mx-auto px-5 py-6 min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <div class="text-9xl font-bold text-heading/10 dark:text-heading-dark/10 mb-4">404</div>
      <h1 class="text-3xl font-bold text-heading dark:text-heading-dark mb-4">
        {t['error.pageNotFound']}
      </h1>
      <p class="text-lg text-text-secondary dark:text-text-secondary-dark mb-8">
        {t['error.description']}
      </p>
      <p class="text-sm text-text-secondary dark:text-text-secondary-dark mb-8">
        {t['error.suggestion']}
      </p>
      <a
        href={lang === 'zh' ? '/sprites-gallery/zh/' : '/sprites-gallery/en/'}
        class="inline-flex items-center justify-center bg-paper dark:bg-paper-dark border border-paper-border dark:border-paper-border-dark rounded-lg cursor-pointer px-5 py-3 text-text dark:text-text-dark no-underline transition-colors hover:bg-paper-border dark:hover:bg-paper-border-dark"
      >
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        {t['footer.backHome']}
      </a>
    </div>
  </div>
</BaseLayout>
