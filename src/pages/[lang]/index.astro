---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SPRITE_SOURCES } from '../../data/sprite-sources';
import { ui, type Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}

const { lang } = Astro.params as { lang: Lang };
const t = ui[lang];

const generations = Array.from(
  new Set(SPRITE_SOURCES.map((s) => s.generation).filter(Boolean))
);
---

<BaseLayout title={t['site.title']} description={t['site.subtitle']}>
  <div class="max-w-7xl mx-auto p-4">
    {/* Header */}
    <header class="flex items-center justify-between gap-4 mb-1">
      <h1 class="text-3xl font-semibold m-0 text-heading dark:text-heading-dark">
        {t['site.title']}
      </h1>
      <div class="flex items-center gap-2">
        <a
          id="github-btn"
          class="inline-flex items-center justify-center bg-paper dark:bg-paper-dark border border-paper-border dark:border-paper-border-dark rounded-lg cursor-pointer p-2 text-text dark:text-text-dark no-underline transition-colors hover:bg-paper-border dark:hover:bg-paper-border-dark"
          href="https://github.com/wangrui2025/sprites-gallery"
          target="_blank"
          rel="noopener noreferrer"
          title={lang === 'zh' ? '查看 GitHub 源码' : 'View source on GitHub'}
          aria-label={lang === 'zh' ? 'GitHub 源码' : 'GitHub source'}
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
        <a
          id="actions-btn"
          class="inline-flex items-center justify-center bg-paper dark:bg-paper-dark border border-paper-border dark:border-paper-border-dark rounded-lg cursor-pointer p-2 text-text dark:text-text-dark no-underline transition-colors hover:bg-paper-border dark:hover:bg-paper-border-dark"
          href="https://github.com/wangrui2025/sprites-gallery/actions"
          target="_blank"
          rel="noopener noreferrer"
          title={lang === 'zh' ? '查看 GitHub Actions' : 'View GitHub Actions'}
          aria-label={lang === 'zh' ? 'GitHub Actions' : 'GitHub Actions'}
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M4.467 6.068v-.002a8.46 8.46 0 0 0-1.99 1.435C1.6 8.6 1.2 10.01 1.2 11.534c0 3.628 2.453 6.702 5.83 7.79.426.078.582-.185.582-.41 0-.202-.007-.734-.01-1.44-2.38.514-2.88-1.147-2.88-1.147-.387-.983-.944-1.245-.944-1.245-.773-.528.059-.518.059-.518.854.06 1.304.877 1.304.877.76 1.3 1.992.924 2.477.707.077-.55.297-.924.54-1.136-1.89-.215-3.878-.945-3.878-4.206 0-.93.332-1.69.877-2.286-.088-.216-.38-1.084.083-2.252 0 0 .715-.228 2.34.873a8.1 8.1 0 0 1 2.13-.287c.724 0 1.451.097 2.13.287 1.624-1.1 2.338-.873 2.338-.873.464 1.168.172 2.036.084 2.652.546.596.876 1.356.876 2.286 0 3.27-1.99 3.988-3.885 4.202.305.263.577.78.577 1.572 0 1.135-.01 2.05-.01 2.33 0 .226.154.49.584.41A8.493 8.493 0 0 0 22 12.017c0-1.524-.4-2.935-1.277-4.099a8.46 8.46 0 0 0-1.99-1.435v.002C19.532 6.068 16.494 4 12 4c-4.494 0-7.532 2.068-7.532 4.068z"/>
          </svg>
        </a>
        <button id="theme-toggle" class="bg-paper dark:bg-paper-dark border border-paper-border dark:border-paper-border-dark rounded-lg cursor-pointer px-3 py-2 text-xl transition-colors hover:bg-paper-border dark:hover:bg-paper-border-dark" aria-label={lang === 'zh' ? '切换主题' : 'Toggle dark mode'}>
          <span class="inline dark:hidden">☀️</span>
          <span class="hidden dark:inline">🌙</span>
        </button>
      </div>
    </header>

    <p class="text-sm text-text-secondary dark:text-text-secondary-dark mb-6 mt-0">
      {t['site.subtitle']}
    </p>

    {/* Control Bar */}
    <div class="flex flex-wrap gap-4 items-end mb-6 p-4 bg-paper dark:bg-paper-dark border border-paper-border dark:border-paper-border-dark rounded-lg">
      <div class="flex flex-col gap-1">
        <label for="poke-id" class="text-xs font-medium text-text-secondary dark:text-text-secondary-dark">{t['control.id']}</label>
        <input
          id="poke-id"
          type="number"
          min="1"
          max="1025"
          value="1"
          class="w-20 px-2 py-1.5 border border-border dark:border-border-dark rounded-md bg-bg dark:bg-bg-dark text-text dark:text-text-dark text-base"
          aria-label={lang === 'zh' ? '宝可梦编号' : 'Pokemon ID'}
        />
      </div>

      <div class="flex flex-col items-start gap-0.5 min-w-32">
        <span id="poke-name" class="text-lg font-semibold text-heading dark:text-heading-dark leading-snug">{t['info.loading']}</span>
        <span id="poke-types" class="flex flex-wrap gap-1 text-sm capitalize"></span>
      </div>

      <button id="btn-random" class="px-4 py-2 rounded-md bg-link text-white font-medium cursor-pointer transition-opacity hover:opacity-90" title="Random (R)">
        {t['control.random']}
      </button>

      <div class="flex flex-col gap-1">
        <label for="gen-filter" class="text-xs font-medium text-text-secondary dark:text-text-secondary-dark">{t['control.generation']}</label>
        <select id="gen-filter" class="px-2 py-1.5 border border-border dark:border-border-dark rounded-md bg-bg dark:bg-bg-dark text-text dark:text-text-dark text-base">
          <option value="">{t['control.all']}</option>
          {generations.map((gen) => (
            <option value={gen}>{gen}</option>
          ))}
        </select>
      </div>
    </div>

    {/* Grid */}
    <div id="sprite-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-4 mb-8">
      {
        SPRITE_SOURCES.map((source) => (
          <div
            class="bg-paper dark:bg-paper-dark border border-paper-border dark:border-paper-border-dark rounded-lg p-4 text-center transition-shadow hover:shadow-lg"
            data-generation={source.generation || ''}
            data-source-id={source.id}
          >
            <div class="sprite-image-wrap relative h-40 flex items-center justify-center mb-3">
              <img
                class={`sprite-img w-auto h-32 object-contain transition-opacity ${source.size === '56×56' ? 'retro' : ''}`}
                data-source={source.id}
                src={source.url(1)}
                alt={source.name}
                width={source.size === '56×56' ? 56 : 96}
                height={source.size === '56×56' ? 56 : 96}
                loading="lazy"
              />
            </div>
            <div class="flex flex-col gap-1.5">
              <h3 class="text-sm font-semibold m-0 text-heading dark:text-heading-dark">{source.name}</h3>
              <div class="flex flex-wrap justify-center gap-1">
                <span class="tag text-xs px-2 py-0.5 rounded-full bg-tag-tech dark:bg-tag-tech-dark text-tag-tech-text dark:text-tag-tech-text-dark">{t['tag.format']}</span>
                <span class="tag text-xs px-2 py-0.5 rounded-full bg-tag-tech dark:bg-tag-tech-dark text-tag-tech-text dark:text-tag-tech-text-dark">{t['tag.size']}</span>
                <span class="tag text-xs px-2 py-0.5 rounded-full bg-tag-tech dark:bg-tag-tech-dark text-tag-tech-text dark:text-tag-tech-text-dark">{t['tag.style']}</span>
              </div>
              <div class="flex justify-center gap-2 mt-2 opacity-85 transition-opacity group-hover:opacity-100">
                <button class="action-btn text-xs px-2 py-1 border border-border dark:border-border-dark rounded bg-transparent text-text dark:text-text-dark cursor-pointer transition-colors hover:bg-tag-field dark:hover:bg-tag-field-dark" data-source={source.id}>
                  {t['action.copyUrl']}
                </button>
                <button class="action-btn text-xs px-2 py-1 border border-border dark:border-border-dark rounded bg-transparent text-text dark:text-text-dark cursor-pointer transition-colors hover:bg-tag-field dark:hover:bg-tag-field-dark" data-source={source.id}>
                  {t['action.setFavicon']}
                </button>
              </div>
            </div>
          </div>
        ))
      }
      <div class="bg-paper dark:bg-paper-dark border border-l-[3px] border-l-violet-500 border-paper-border dark:border-paper-border-dark rounded-lg p-4 text-center transition-shadow hover:shadow-lg" data-source-id="favicon-preview">
        <div class="sprite-image-wrap relative h-40 flex items-center justify-center mb-3">
          <img
            id="favicon-preview-img"
            src="/sprites-gallery/favicons/pikachu.png"
            alt={t['section.faviconPreview']}
            width="96"
            height="96"
            class="[image-rendering:pixelated]"
          />
        </div>
        <div class="flex flex-col gap-1.5">
          <h3 class="text-sm font-semibold m-0 text-heading dark:text-heading-dark">{t['section.faviconPreview']}</h3>
          <div class="flex flex-wrap justify-center gap-1">
            <span class="text-xs px-2 py-0.5 rounded-full bg-tag-tech dark:bg-tag-tech-dark text-tag-tech-text dark:text-tag-tech-text-dark">{t['tag.format']}</span>
            <span class="text-xs px-2 py-0.5 rounded-full bg-tag-tech dark:bg-tag-tech-dark text-tag-tech-text dark:text-tag-tech-text-dark">32×32</span>
            <span class="text-xs px-2 py-0.5 rounded-full bg-tag-tech dark:bg-tag-tech-dark text-tag-tech-text dark:text-tag-tech-text-dark">{t['tag.local']}</span>
            <span class="text-xs px-2 py-0.5 rounded-full bg-violet-500 text-white">{t['tag.mapping']}</span>
          </div>
          <div class="flex justify-center gap-2 mt-2">
            <span class="text-xs text-text-secondary dark:text-text-secondary-dark text-center">{t['tag.currentBrowser']}</span>
          </div>
        </div>
      </div>
    </div>

    {/* Code Snippet */}
    <div class="p-4 bg-paper dark:bg-paper-dark border border-paper-border dark:border-paper-border-dark rounded-lg mb-8">
      <h2 class="text-base font-semibold mb-2 text-heading dark:text-heading-dark">{t['section.urlTemplate']}</h2>
      <pre class="code-block p-3 rounded-md overflow-x-auto text-sm m-0 mb-3"><code id="url-template">Select a source to view its URL template</code></pre>
      <button id="copy-template" class="px-4 py-2 rounded-md bg-link text-white font-medium cursor-pointer transition-opacity hover:opacity-90">{t['action.copyTemplate']}</button>
    </div>

    <footer class="text-center py-4">
      <a href="https://wangrui2025.github.io/" class="text-link dark:text-link-dark no-underline font-medium hover:underline">{t['footer.backHome']}</a>
    </footer>
  </div>

  {/* Toast */}
  <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 translate-y-4 px-5 py-2.5 bg-heading dark:bg-heading-dark text-bg dark:text-bg-dark rounded-lg text-sm opacity-0 pointer-events-none transition-all z-50" role="status" aria-live="polite"></div>

  <script>
    import '../../script/gallery';
  </script>
</BaseLayout>
